  // Rules are installed as project instruction files and referenced from project config.
  "rules": {
    "codebase-memory": {
      "title": "Codebase Memory First",
      "description": "Prefer the project code graph for architecture, symbol, call-path, and impact discovery.",
      "tags": ["code-intelligence", "workflow"],
      "path": "rules/codebase-memory.md",
    },
    "parallel-agents": {
      "title": "Parallel Agent Orchestration",
      "description": "Fan out independent workstreams to focused subagents and reconcile results through the primary agent.",
      "tags": ["agents", "orchestration"],
      "path": "rules/parallel-agents.md",
    },
  },

  // A single agent installs one file; a team installs every agent in its folder as one unit.
  "agents": {
    "search": {
      "type": "single",
      "title": "Search Researcher",
      "description": "Collects, validates, and summarizes current external information with source evidence.",
      "tags": ["research", "web"],
      "path": "agents/search.md",
    },
    "software-architect": {
      "type": "single",
      "title": "Software Architect",
      "description": "Analyzes system boundaries, trade-offs, migration paths, and architecture decisions.",
      "tags": ["architecture", "design"],
      "path": "agents/software-architect.md",
    },
    "researcher": {
      "type": "team",
      "title": "Research Team",
      "description": "Orchestrated web, academic, community, validation, and synthesis research team.",
      "tags": ["research", "deep-research"],
      "path": "agents/researcher",
    },
    "review-team": {
      "type": "team",
      "title": "Review Team",
      "description": "Producer-reviewer team with a lead, security reviewer, and quality reviewer.",
      "tags": ["code-review", "security"],
      "path": "agents/review-team",
    },
  },

  "profiles": [
    {
      "id": "source-control",
      "title": "Source Control",
      "description": "Local repository intelligence and GitHub collaboration.",
      "tags": ["git", "github"],
      "mcps": ["codebase-memory", "git", "github"],
      "skills": [],
      "rules": ["codebase-memory"],
    },
    {
      "id": "research",
      "title": "Research and Documentation",
      "description": "Current web, framework, platform, and model documentation.",
      "tags": ["documentation", "research"],
      "mcps": [
        "context7",
        "exa",
        "microsoft-docs",
        "google-developer-knowledge",
        "huggingface",
        "svelte",
      ],
      "skills": [],
      "rules": ["parallel-agents"],
      "agents": ["researcher"],
    },
    {
      "id": "cloud-platforms",
      "title": "Cloud Platforms",
      "description": "AWS, Azure, and Docker platform tooling.",
      "tags": ["cloud", "containers"],
      "mcps": ["aws", "azure", "docker"],
      "skills": [],
    },
    {
      "id": "cloudflare",
      "title": "Cloudflare Workers",
      "description": "Cloudflare platform MCPs with a curated Workers skill set.",
      "tags": ["cloudflare", "edge", "typescript"],
      "mcps": [
        "cloudflare-docs",
        "cloudflare-workers-builds",
        "cloudflare-workers-bindings",
        "cloudflare-observability",
      ],
      "skills": [
        { "source": "cloudflare", "path": "cloudflare" },
        { "source": "cloudflare", "path": "workers-best-practices" },
        { "source": "cloudflare", "path": "wrangler" },
        { "source": "cloudflare", "path": "durable-objects" },
        { "source": "cloudflare", "path": "agents-sdk" },
      ],
    },
    {
      "id": "clickhouse",
      "title": "ClickHouse",
      "description": "ClickHouse MCP plus architecture, Node.js, and local-development skills.",
      "tags": ["analytics", "clickhouse", "database"],
      "mcps": ["clickhouse"],
      "skills": [
        { "source": "clickhouse", "path": "clickhouse-best-practices" },
        { "source": "clickhouse", "path": "clickhouse-js-node-coding" },
        { "source": "clickhouse", "path": "clickhousectl-local-dev" },
      ],
    },
    {
