{
  "version": 1,

  // MCP definitions in this registry are copied only to the active project's config.
  "mcps": {
    "codebase-memory": {
      "title": "Codebase Memory",
      "description": "Code graph, architecture, symbol search, and change impact analysis.",
      "tags": ["code-intelligence", "memory"],
      "config": {
        "type": "local",
        "command": ["codebase-memory-mcp"],
        "enabled": false
      }
    },
    "git": {
      "title": "Git",
      "description": "Local Git repository operations through MCP.",
      "tags": ["git", "source-control"],
      "config": {
        "type": "local",
        "command": ["uvx", "mcp-server-git"],
        "enabled": false
      }
    },
    "github": {
      "title": "GitHub",
      "description": "GitHub repositories, issues, pull requests, and code search.",
      "tags": ["github", "source-control"],
      "config": {
        "type": "remote",
        "url": "https://api.githubcopilot.com/mcp/",
        "headers": { "Authorization": "Bearer {env:GITHUB_TOKEN}" },
        "enabled": false
      }
    },
    "context7": {
      "title": "Context7",
      "description": "Current library and framework documentation.",
      "tags": ["documentation", "research"],
      "config": {
        "type": "remote",
        "url": "https://mcp.context7.com/mcp",
        "headers": { "Authorization": "Bearer {env:CONTEXT7_API_KEY}" },
        "enabled": false
      }
    },
    "exa": {
      "title": "Exa",
      "description": "Web search and page retrieval for technical research.",
      "tags": ["research", "web"],
      "config": {
        "type": "remote",
        "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_fetch_exa,web_search_advanced_exa",
        "headers": { "x-api-key": "{env:EXA_API_KEY}" },
        "enabled": false
      }
    },
    "microsoft-docs": {
      "title": "Microsoft Learn",
      "description": "Official Microsoft product and platform documentation.",
      "tags": ["documentation", "microsoft"],
      "config": {
        "type": "remote",
        "url": "https://learn.microsoft.com/api/mcp",
        "enabled": false
      }
    },
    "google-developer-knowledge": {
      "title": "Google Developer Knowledge",
      "description": "Official Google developer documentation and knowledge.",
      "tags": ["documentation", "google"],
      "config": {
        "type": "remote",
        "url": "https://developerknowledge.googleapis.com/mcp",
        "headers": { "X-Goog-Api-Key": "{env:GOOGLE_DEVELOPER_API_KEY}" },
        "enabled": false
      }
    },
    "huggingface": {
      "title": "Hugging Face",
      "description": "Hugging Face models, datasets, and platform resources.",
      "tags": ["ai", "models"],
      "config": {
        "type": "remote",
        "url": "https://huggingface.co/mcp",
        "headers": { "Authorization": "Bearer {env:HF_TOKEN}" },
        "enabled": false
      }
    },
    "svelte": {
      "title": "Svelte",
      "description": "Official Svelte framework documentation.",
      "tags": ["frontend", "svelte"],
      "config": {
        "type": "remote",
        "url": "https://mcp.svelte.dev/mcp",
        "enabled": false
      }
    },
    "aws": {
      "title": "AWS Documentation",
      "description": "AWS service documentation through the AWS Labs MCP server.",
      "tags": ["aws", "cloud"],
      "config": {
        "type": "local",
        "command": ["uvx", "awslabs.aws-documentation-mcp-server@latest"],
        "environment": {
          "FASTMCP_LOG_LEVEL": "ERROR",
          "AWS_DOCUMENTATION_PARTITION": "aws"
        },
        "enabled": false
      }
    },
    "docker": {
      "title": "Docker",
      "description": "Docker engine and container management.",
      "tags": ["containers", "docker"],
      "config": {
        "type": "local",
        "command": ["uvx", "docker-mcp"],
        "enabled": false
      }
    },
    "azure": {
      "title": "Azure",
      "description": "Microsoft Azure resource and platform operations.",
      "tags": ["azure", "cloud"],
      "config": {
        "type": "local",
        "command": ["bunx", "-y", "@azure/mcp@latest", "server", "start"],
        "enabled": false
      }
    },
    "cloudflare-docs": {
      "title": "Cloudflare Docs",
      "description": "Cloudflare developer documentation.",
      "tags": ["cloudflare", "documentation"],
      "config": {
        "type": "remote",
        "url": "https://docs.mcp.cloudflare.com/mcp",
        "enabled": false
      }
    },
    "cloudflare-workers-builds": {
      "title": "Cloudflare Workers Builds",
      "description": "Cloudflare Workers build diagnostics.",
      "tags": ["cloudflare", "workers"],
      "config": {
        "type": "remote",
        "url": "https://builds.mcp.cloudflare.com/mcp",
        "enabled": false
      }
    },
    "cloudflare-workers-bindings": {
      "title": "Cloudflare Workers Bindings",
      "description": "Cloudflare Workers binding configuration.",
      "tags": ["cloudflare", "workers"],
      "config": {
        "type": "remote",
        "url": "https://bindings.mcp.cloudflare.com/mcp",
        "enabled": false
      }
    },
    "cloudflare-observability": {
      "title": "Cloudflare Observability",
      "description": "Cloudflare Workers logs and observability.",
      "tags": ["cloudflare", "observability"],
      "config": {
        "type": "remote",
        "url": "https://observability.mcp.cloudflare.com/mcp",
        "enabled": false
      }
    },
    "clickhouse": {
      "title": "ClickHouse",
      "description": "ClickHouse Cloud database operations and documentation.",
      "tags": ["clickhouse", "database"],
      "config": {
        "type": "remote",
        "url": "https://mcp.clickhouse.cloud/mcp",
        "enabled": false
      }
    },
    "redpanda": {
      "title": "Redpanda",
      "description": "Redpanda streaming platform documentation.",
      "tags": ["kafka", "redpanda", "streaming"],
      "config": {
        "type": "remote",
        "url": "https://docs.redpanda.com/mcp",
        "enabled": false
      }
    },
    "cloakbrowser": {
      "title": "CloakBrowser",
      "description": "Privacy-oriented Playwright browser automation.",
      "tags": ["browser", "playwright"],
      "config": {
        "type": "local",
        "command": ["bunx", "-y", "cloakbrowser-mcp@latest"],
        "environment": {
          "PLAYWRIGHT_MCP_OUTPUT_DIR": ".cloakbrowser-artifacts",
          "PLAYWRIGHT_MCP_HEADLESS": "true"
        },
        "enabled": false
      }
    },
    "playwright": {
      "title": "Playwright",
      "description": "Cross-browser web automation through Playwright.",
      "tags": ["browser", "playwright", "testing"],
      "config": {
        "type": "local",
        "command": ["bunx", "-y", "@playwright/mcp@latest", "--browser", "chrome"],
        "enabled": false
      }
    },
    "chrome.devtools": {
      "title": "Chrome DevTools",
      "description": "Chrome inspection, debugging, and performance tooling.",
      "tags": ["browser", "chrome", "debugging"],
      "config": {
        "type": "local",
        "command": ["bunx", "-y", "chrome-devtools-mcp@latest", "--autoConnect", "--no-usage-statistics"],
        "enabled": false
      }
    },
    "firefox.devtools": {
      "title": "Firefox DevTools",
      "description": "Firefox inspection and debugging tooling.",
      "tags": ["browser", "debugging", "firefox"],
      "config": {
        "type": "local",
        "command": ["bunx", "-y", "@mozilla/firefox-devtools-mcp@latest", "--headless", "--viewport", "1280x720"],
        "environment": { "START_URL": "about:blank" },
        "enabled": false
      }
    },
    "burp.pro": {
      "title": "Burp Suite Professional",
      "description": "Burp Suite Professional integration through its local MCP proxy.",
      "tags": ["security", "web-security"],
      "config": {
        "type": "local",
        "command": ["java", "-jar", "{env:HOME}/.BurpSuite/mcp-proxy.jar", "--sse-url", "http://127.0.0.1:9876"],
        "enabled": false
      }
    },
    "filescan": {
      "title": "FileScan",
      "description": "File and malware analysis tooling.",
      "tags": ["malware", "security"],
      "config": {
        "type": "local",
        "command": ["filescan-mcp"],
        "enabled": false
      }
    },
    "microsoft.defender": {
      "title": "Microsoft Defender",
      "description": "Microsoft Defender security operations.",
      "tags": ["microsoft", "security"],
      "config": {
        "type": "local",
        "command": ["microsoft-defender-mcp-server"],
        "enabled": false
      }
    },
    "cyble.vision": {
      "title": "Cyble Vision",
      "description": "Cyber threat intelligence from Cyble Vision.",
      "tags": ["security", "threat-intelligence"],
      "config": {
        "type": "local",
        "command": ["cyble-mcp-server"],
        "enabled": false
      }
    },
    "wiz": {
      "title": "Wiz",
      "description": "Wiz cloud security platform integration.",
      "tags": ["cloud-security", "security"],
      "config": {
        "type": "remote",
        "url": "https://mcp.app.wiz.io",
        "headers": {
          "Wiz-Client-Id": "{env:WIZ_CLIENT_ID}",
          "Wiz-Client-Secret": "{env:WIZ_CLIENT_SECRET}",
          "Wiz-DataCenter": "{env:WIZ_TENANT_DC}"
        },
        "enabled": false
      }
    },
    "ida.pro": {
      "title": "IDA Pro",
      "description": "IDA Pro reverse engineering through idalib-mcp.",
      "tags": ["reverse-engineering", "security"],
      "config": {
        "type": "local",
        "command": ["uv", "run", "idalib-mcp", "--stdio", "--max-workers", "8"],
        "environment": { "IDADIR": "/Applications/IDA Professional 9.3.app/Contents/MacOS" },
        "enabled": false
      }
    },
    "docs.rs": {
      "title": "docs.rs",
      "description": "Rust crate documentation search.",
      "tags": ["documentation", "rust"],
      "config": {
        "type": "local",
        "command": ["bunx", "-y", "@nuskey8/docs-rs-mcp@latest"],
        "enabled": false
      }
    },
    "crates.io": {
      "title": "crates.io",
      "description": "Rust crate registry search and metadata.",
      "tags": ["packages", "rust"],
      "config": {
        "type": "local",
        "command": ["cratesio-mcp"],
        "enabled": false
      }
    },
    "cargo": {
      "title": "Cargo",
      "description": "Cargo project and dependency operations.",
      "tags": ["build", "rust"],
      "config": {
        "type": "local",
        "command": ["cargo-mcp", "serve"],
        "enabled": false
      }
    },
    "ferroscope": {
      "title": "Ferroscope",
      "description": "Rust codebase analysis and inspection.",
      "tags": ["code-intelligence", "rust"],
      "config": {
        "type": "local",
        "command": ["ferroscope"],
        "enabled": false
      }
    },
    "javadoc": {
      "title": "Javadoc",
      "description": "Java API documentation search.",
      "tags": ["documentation", "java"],
      "config": {
        "type": "local",
        "command": ["bunx", "-y", "javadoc-mcp"],
        "enabled": false
      }
    },
    "xcodebuild": {
      "title": "XcodeBuild",
      "description": "Xcode project build, test, and simulator operations.",
      "tags": ["apple", "ios", "xcode"],
      "config": {
        "type": "local",
        "command": ["bunx", "-y", "xcodebuildmcp@latest", "mcp"],
        "enabled": false
      }
    },
    "android": {
      "title": "Android",
      "description": "Android development and device operations.",
      "tags": ["android", "mobile"],
      "config": {
        "type": "local",
        "command": ["uvx", "--python", "3.13", "android-mcp"],
        "enabled": false
      }
    },
    "d2": {
      "title": "D2",
      "description": "D2 diagram generation.",
      "tags": ["diagrams", "documentation"],
      "config": {
        "type": "local",
        "command": ["d2-mcp", "--image-type", "png"],
        "enabled": false
      }
    },
    "time": {
      "title": "Time",
      "description": "Timezone and current-time utilities.",
      "tags": ["productivity", "time"],
      "config": {
        "type": "local",
        "command": ["uvx", "mcp-server-time"],
        "enabled": false
      }
    },
    "atlassian": {
      "title": "Atlassian",
      "description": "Jira and Confluence operations.",
      "tags": ["atlassian", "productivity"],
      "config": {
        "type": "local",
        "command": ["uvx", "mcp-atlassian"],
        "environment": {
          "JIRA_URL": "{env:JIRA_URL}",
          "JIRA_USERNAME": "{env:JIRA_USERNAME}",
          "JIRA_API_TOKEN": "{env:JIRA_API_TOKEN}",
          "CONFLUENCE_URL": "{env:CONFLUENCE_URL}",
          "CONFLUENCE_USERNAME": "{env:CONFLUENCE_USERNAME}",
          "CONFLUENCE_API_TOKEN": "{env:CONFLUENCE_API_TOKEN}"
        },
        "enabled": false
      }
    },
    "adspower-local-api": {
      "title": "AdsPower Local API",
      "description": "AdsPower browser profile control through the local API.",
      "tags": ["adspower", "browser"],
      "config": {
        "type": "local",
        "command": ["bunx", "-y", "local-api-mcp-typescript"],
        "environment": { "PORT": "50325", "API_KEY": "{env:ADSPOWER_API_KEY}" },
        "enabled": false
      }
    }
  },

  // Git sources are pinned so selecting a skill is reproducible and reviewable.
  "skillSources": {
    "custom": {
      "type": "local",
      "title": "OpenCode Manager Registry",
      "path": "skills",
      "skillsPath": "."
    },
    "cloudflare": {
      "type": "git",
      "title": "Cloudflare Skills",
      "repository": "https://github.com/cloudflare/skills.git",
      "revision": "70215303d44a81a0db3219428f4825b604fc6061",
      "skillsPath": "skills",
      "license": "Apache-2.0"
    },
    "clickhouse": {
      "type": "git",
      "title": "ClickHouse Agent Skills",
      "repository": "https://github.com/ClickHouse/agent-skills.git",
      "revision": "65ce71fce803014afb69279535c82c72dc55d9ba",
      "skillsPath": "skills",
      "license": "Apache-2.0"
    },
    "redpanda": {
      "type": "git",
      "title": "Redpanda Skills",
      "repository": "https://github.com/redpanda-data/skills.git",
      "revision": "a2d1ddbca08649e79617d9586dfc3b3f0ae8b2fd",
      "skillsPath": "skills",
      "license": "Apache-2.0"
    },
    "qdrant": {
      "type": "git",
      "title": "Qdrant Skills",
      "repository": "https://github.com/qdrant/skills.git",
      "revision": "e24485f0e76d3d4504bf5045ead9a42b56561521",
      "skillsPath": "skills",
      "license": "Apache-2.0"
    },
    "windmill": {
      "type": "git",
      "title": "Windmill CLI Skills",
      "repository": "https://github.com/windmill-labs/windmill-cli-docs.git",
      "revision": "8532494d66f6c5053435f5b4f8401923f8aa5f4a",
      "skillsPath": "skills"
    }
  },

  "profiles": [
    {
      "id": "source-control",
      "title": "Source Control",
      "description": "Local repository intelligence and GitHub collaboration.",
      "tags": ["git", "github"],
      "mcps": ["codebase-memory", "git", "github"],
      "skills": []
    },
    {
      "id": "research",
      "title": "Research and Documentation",
      "description": "Current web, framework, platform, and model documentation.",
      "tags": ["documentation", "research"],
      "mcps": ["context7", "exa", "microsoft-docs", "google-developer-knowledge", "huggingface", "svelte"],
      "skills": []
    },
    {
      "id": "cloud-platforms",
      "title": "Cloud Platforms",
      "description": "AWS, Azure, and Docker platform tooling.",
      "tags": ["cloud", "containers"],
      "mcps": ["aws", "azure", "docker"],
      "skills": []
    },
    {
      "id": "cloudflare",
      "title": "Cloudflare Workers",
      "description": "Cloudflare platform MCPs with a curated Workers skill set.",
      "tags": ["cloudflare", "edge", "typescript"],
      "mcps": ["cloudflare-docs", "cloudflare-workers-builds", "cloudflare-workers-bindings", "cloudflare-observability"],
      "skills": [
        { "source": "cloudflare", "path": "cloudflare" },
        { "source": "cloudflare", "path": "workers-best-practices" },
        { "source": "cloudflare", "path": "wrangler" },
        { "source": "cloudflare", "path": "durable-objects" },
        { "source": "cloudflare", "path": "agents-sdk" }
      ]
    },
    {
      "id": "clickhouse",
      "title": "ClickHouse",
      "description": "ClickHouse MCP plus architecture, Node.js, and local-development skills.",
      "tags": ["analytics", "clickhouse", "database"],
      "mcps": ["clickhouse"],
      "skills": [
        { "source": "clickhouse", "path": "clickhouse-best-practices" },
        { "source": "clickhouse", "path": "clickhouse-js-node-coding" },
        { "source": "clickhouse", "path": "clickhousectl-local-dev" }
      ]
    },
    {
      "id": "redpanda",
      "title": "Redpanda",
      "description": "Redpanda streaming MCP with core broker, Connect, and rpk skills.",
      "tags": ["kafka", "redpanda", "streaming"],
      "mcps": ["redpanda"],
      "skills": [
        { "source": "redpanda", "path": "streaming" },
        { "source": "redpanda", "path": "connect" },
        { "source": "redpanda", "path": "rpk" }
      ]
    },
    {
      "id": "qdrant",
      "title": "Qdrant",
      "description": "Qdrant deployment, SDK, monitoring, and search-quality skills.",
      "tags": ["qdrant", "vector-database"],
      "mcps": [],
      "skills": [
        { "source": "qdrant", "path": "qdrant-deployment-options" },
        { "source": "qdrant", "path": "qdrant-clients-sdk" },
        { "source": "qdrant", "path": "qdrant-monitoring" },
        { "source": "qdrant", "path": "qdrant-search-quality" }
      ]
    },
    {
      "id": "windmill",
      "title": "Windmill",
      "description": "Windmill CLI, flow authoring, Bun scripts, and preview workflows.",
      "tags": ["automation", "windmill", "workflow"],
      "mcps": [],
      "skills": [
        { "source": "windmill", "path": "cli-commands" },
        { "source": "windmill", "path": "write-flow" },
        { "source": "windmill", "path": "write-script-bun" },
        { "source": "windmill", "path": "preview" }
      ]
    },
    {
      "id": "browser",
      "title": "Browser Automation",
      "description": "Browser testing, debugging, profiling, and profile automation.",
      "tags": ["browser", "testing"],
      "mcps": ["cloakbrowser", "playwright", "chrome.devtools", "firefox.devtools", "adspower-local-api"],
      "skills": []
    },
    {
      "id": "security",
      "title": "Security",
      "description": "Web security, threat intelligence, cloud defense, malware analysis, and reverse engineering.",
      "tags": ["security"],
      "mcps": ["burp.pro", "filescan", "microsoft.defender", "cyble.vision", "wiz", "ida.pro"],
      "skills": []
    },
    {
      "id": "rust",
      "title": "Rust Development",
      "description": "Rust documentation, packages, Cargo, and code intelligence.",
      "tags": ["rust"],
      "mcps": ["docs.rs", "crates.io", "cargo", "ferroscope"],
      "skills": []
    },
    {
      "id": "mobile-jvm",
      "title": "Mobile and JVM",
      "description": "Java, Android, iOS, and Xcode development tooling.",
      "tags": ["android", "ios", "java", "mobile"],
      "mcps": ["javadoc", "xcodebuild", "android"],
      "skills": []
    },
    {
      "id": "productivity",
      "title": "Productivity",
      "description": "Diagrams, time utilities, Jira, and Confluence.",
      "tags": ["documentation", "productivity"],
